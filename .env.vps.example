# VERDELIMP ERP — EXEMPLO PARA VPS CONTABO
# Copie este arquivo para .env.production no servidor.
# NUNCA envie .env.production real para o GitHub.

# Banco PostgreSQL interno do Docker Compose
POSTGRES_DB=verdelimp_erp
POSTGRES_USER=verdelimp
POSTGRES_PASSWORD=troque_por_uma_senha_forte

# URL pública final do ERP
NEXTAUTH_URL=https://erp.seudominio.com.br
NEXTAUTH_SECRET=gere_uma_string_forte_com_openssl_rand_base64_32

# Porta do ERP no host (VPS compartilhada com EJC/S2/site — confira portas livres
# com: ss -tlnp | grep LISTEN). O Nginx do ERP deve apontar para esta porta.
APP_PORT=3010

# Aplicação
NEXT_PUBLIC_APP_NAME=Verdelimp ERP
NEXT_PUBLIC_APP_VERSION=2.2.0

# Segurança fiscal
FISCAL_ENVIRONMENT=homologacao
SEFAZ_CERTIFICATE_ENABLED=false
SEFAZ_CERTIFICATE_STORAGE_MODE=disabled
ESOCIAL_ENABLED=false
REINF_ENABLED=false

# APIs públicas
PNCP_ENABLED=true
CEP_PROVIDER=viacep
IBGE_ENABLED=true
CNPJ_PROVIDER=brasilapi

# IA — somente server-side (GROQ, plano gratuito em console.groq.com)
# Usada por: proposta por edital, análise de licitação/preço, cronograma,
# logística, chat de ajuda e transcrição de voz. Sem a chave, esses
# recursos retornam erro amigável; o restante do ERP funciona normalmente.
GROQ_API_KEY=

# Seed inicial — senha do primeiro acesso dos usuários admin/gestor.
# OBRIGATÓRIO definir em produção antes de rodar `npm run prisma:seed`.
SEED_ADMIN_PASSWORD=

# WhatsApp
WHATSAPP_PROVIDER=disabled
WHATSAPP_ADMIN_NUMBER=5531999990000
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=verdelimp
ZAPI_URL=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# E-mail (envio SMTP)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@verdelimp.com.br

# E-mail (busca IMAP em "Buscar no E-mail") — se vazio, herda SMTP_USER/SMTP_PASS.
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
