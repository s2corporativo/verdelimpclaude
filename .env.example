# ─────────────────────────────────────────────────
# VERDELIMP ERP — VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha os valores
# NUNCA commitar o .env com valores reais
# ─────────────────────────────────────────────────

# Banco de dados (Render PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/verdelimp?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="gere-com-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_NAME="Verdelimp ERP"
NEXT_PUBLIC_APP_VERSION="2.2.0"

# Ambiente fiscal
FISCAL_ENVIRONMENT="homologacao"
SEFAZ_CERTIFICATE_ENABLED="false"
SEFAZ_CERTIFICATE_STORAGE_MODE="disabled"
ESOCIAL_ENABLED="false"
REINF_ENABLED="false"

# APIs Públicas (sem token necessário)
PNCP_ENABLED="true"
CEP_PROVIDER="viacep"
IBGE_ENABLED="true"
CNPJ_PROVIDER="brasilapi"

# IA — SOMENTE SERVER-SIDE — NUNCA NEXT_PUBLIC_
AI_ENABLED="true"
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""

# Banco/Financeiro (a contratar)
BANK_API_ENABLED="false"
BANK_PROVIDER=""
BANK_API_CLIENT_ID=""
BANK_API_CLIENT_SECRET=""

# ─────────────────────────────────────────────────────────────────
# WHATSAPP — ALERTAS AUTOMÁTICOS
# Provedor: evolution (gratuito self-hosted) | zapi (R$69/mês) | disabled
# ─────────────────────────────────────────────────────────────────
WHATSAPP_PROVIDER="disabled"
WHATSAPP_ADMIN_NUMBER="5531999990000"

# Evolution API (self-hosted - https://evolution-api.com)
EVOLUTION_API_URL="https://seu-servidor:8080"
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE="verdelimp"

# Z-API (pago - https://www.z-api.io)
ZAPI_URL=""
ZAPI_TOKEN=""
ZAPI_CLIENT_TOKEN=""
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@verdelimp.com.br"
